# Server
PORT=3000
NODE_ENV=development

# Database - PostgreSQL
DATABASE_URL="postgresql://postgres:cc@localhost:5432/erp_db?schema=public"
# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS / Frontend
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_ROUNDS=10

#tự điền dô như .env nha 
#Cloudinary
CLOUDINARY_CLOUD_NAME=tên_cloud
CLOUDINARY_API_KEY=mã_api_key
CLOUDINARY_API_SECRET=mã_api_secret